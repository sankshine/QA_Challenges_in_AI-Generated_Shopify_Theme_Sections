{% comment %} BAD: AI-generated — no limit, no pagination {% endcomment %}
{% for product in collections['summer-sale'].products %}
  <div class="promo-card">
    <img src="{{ product.featured_image | img_url: 'master' }}" alt="{{ product.title }}">
    <h3>{{ product.title }}</h3>
